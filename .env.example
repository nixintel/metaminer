# Copy to .env and adjust values for your environment.
# All settings have sensible defaults for Docker Compose — only override what you need.

# Application
APP_NAME=metaminer
DEBUG=false

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql+asyncpg://metaminer:metaminer@postgres:5432/metaminer

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_CONCURRENCY=4

# File retention
RETAIN_FILES=false
TEMP_FILE_TTL_HOURS=1

# PDF mode (runs exiftool rollback extraction on every PDF by default)
PDF_MODE_ENABLED=true

# exiftool
EXIFTOOL_PATH=exiftool
EXIFTOOL_TIMEOUT_SECONDS=30

# Crawler
CRAWLER_DEPTH_LIMIT=3
CRAWLER_DOWNLOAD_DELAY=1.0
CRAWLER_AUTOTHROTTLE_ENABLED=true
CRAWLER_CONCURRENT_REQUESTS=8
CRAWLER_ROBOTSTXT_OBEY=true
# User agent preset: chrome-windows (default), chrome-mac, chrome-linux,
# firefox-windows, firefox-mac, safari-mac, edge-windows, googlebot
CRAWLER_USER_AGENT_PRESET=chrome-windows
# Override with a custom string (leave blank to use the preset above)
CRAWLER_USER_AGENT=
CRAWLER_MAX_FILE_SIZE_MB=100
# Proxy (leave blank to disable). Supports http, https, socks5.
# Examples: http://proxy.example.com:8080  or  socks5://user:pass@host:1080
CRAWLER_PROXY=
CRAWLER_PROXY_USERNAME=
CRAWLER_PROXY_PASSWORD=

CRAWLER_PARTIAL_DOWNLOAD_ENABLED=true
CRAWLER_PARTIAL_DOWNLOAD_SIZE_MB=2
CRAWLER_FULL_DOWNLOAD_ENABLED=false

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
LOG_DB_RETENTION_DAYS=90
LOG_MAX_FILE_SIZE_MB=50
LOG_BACKUP_COUNT=5

# Frontend
API_BASE_URL=http://api:8000
